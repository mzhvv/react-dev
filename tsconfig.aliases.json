// tsconfig.aliases.json

{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      // #region apps(microfrontends)

      "@home/*": ["./src/apps/home/*"],
      "@home": ["./src/apps/home"],
      "@documentation/*": ["./src/apps/documentation/*"],
      "@documentation": ["./src/apps/documentation"],
      "@examples/*": ["./src/apps/examples/*"],
      "@examples": ["./src/apps/examples"],
      "@ui/*": ["./src/apps/ui/*"],
      "@ui": ["./src/apps/ui"],

      // #endregion

      // #region required packages(@mzhvv)/framework

      "@template-app/*": ["./src/packages/framework/template-app/*"],
      "@template-app": ["./src/packages/framework/template-app"],

      "@packages/*": ["./src/packages/*"],
      "@core/*": ["./src/core/*"],
      "@business/*": ["./src/business/*"],

      "@accumulator": ["./src/apps/__accumulator__"],
      "@apps/*": ["./src/apps/*"],
      "@aggregator": ["./src/host/__aggregator__"],
      "@host/*": ["./src/host/*"],

      "@/*": ["./src/*"],
      "@public/*": ["./public/*"]

      // #endregion
    }
  }
}
