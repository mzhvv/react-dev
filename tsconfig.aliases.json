// tsconfig.aliases.json

{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@mzhvv/*": ["./src/packages/@mzhvv/*"],
      "@packages/*": ["./src/packages/*"],

      "@core/*": ["./src/core/*"],
      "@business/*": ["./src/business/*"],

      "@ui/*": ["./src/ui/*"],

      "@template-app/*": ["./src/apps/@mzhvv/template-app/*"],
      "@accumulator/*": ["./src/apps/__accumulator__/*"],
      "@apps/*": ["./src/apps/*"],

      "@aggregator/*": ["./src/main/__aggregator__/*"],
      "@main/*": ["./src/main/*"],

      "@/*": ["./src/*"],

      "@public/*": ["./public/*"]
    }
  }
}
